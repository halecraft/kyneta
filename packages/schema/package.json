  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halecraft/kyneta",
    "directory": "packages/schema"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
