{
  "name": "@kyneta/schema",
  "version": "1.3.1",
  "description": "Schema interpreter algebra — pure structure, pluggable interpretations",
  "author": "Duane Johnson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halecraft/kyneta",
    "directory": "packages/schema"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./basic": {
      "types": "./dist/basic/index.d.ts",
      "import": "./dist/basic/index.js",
      "default": "./dist/basic/index.js"
    },
    "./src": "./src/index.ts",
    "./src/*": "./src/*",
    "./basic/src": "./src/basic/index.ts",
    "./basic/src/*": "./src/basic/*"
  },
  "scripts": {
    "build": "tsdown",
    "test": "verify logic",
    "verify": "verify"
  },
  "dependencies": {
    "@kyneta/changefeed": "workspace:^"
  },
  "devDependencies": {
    "@kyneta/changefeed": "workspace:^",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.2",
    "vitest": "^4.0.17"
  }
}
