      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./basic": {
      "types": "./dist/basic/index.d.ts",
      "import": "./dist/basic/index.js",
      "default": "./dist/basic/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "verify logic",
    "verify": "verify"
  },
  "dependencies": {
    "@kyneta/changefeed": "workspace:^",
    "@kyneta/machine": "workspace:^",
    "@kyneta/random": "workspace:^",
    "@sindresorhus/fnv1a": "^3.1.0"
  },
  "devDependencies": {
    "@kyneta/changefeed": "workspace:^",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
