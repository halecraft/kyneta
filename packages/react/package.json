{
  "name": "@kyneta/react",
  "version": "1.3.1",
  "description": "Thin React bindings over @kyneta/schema + @kyneta/exchange",
  "author": "Duane Johnson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halecraft/kyneta",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src": "./src/index.ts",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "tsdown",
    "test": "verify logic",
    "verify": "verify"
  },
  "peerDependencies": {
    "@kyneta/changefeed": "^1.3.1",
    "@kyneta/exchange": "^1.3.1",
    "@kyneta/schema": "^1.3.1",
    "react": ">=18"
  },
  "devDependencies": {
    "@kyneta/changefeed": "workspace:^",
    "@kyneta/exchange": "workspace:^",
    "@kyneta/loro-schema": "workspace:^",
    "@kyneta/schema": "workspace:^",
    "@kyneta/transport": "workspace:^",
    "@kyneta/yjs-schema": "workspace:^",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.2",
    "vitest": "^4.0.17"
  }
}
