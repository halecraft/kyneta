{
  "name": "@kyneta/sse-network-adapter",
  "version": "0.0.1",
  "description": "SSE (Server-Sent Events) network adapter for @kyneta/exchange — client, server, and Express integration",
  "author": "Duane Johnson",
  "license": "MIT",
  "type": "module",
  "files": ["dist", "src"],
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "tsup",
    "test": "verify logic",
    "verify": "verify"
  },
  "peerDependencies": {
    "@kyneta/exchange": ">=0.0.1",
    "@kyneta/wire": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kyneta/exchange": "workspace:*",
    "@kyneta/wire": "workspace:*",
    "@kyneta/schema": "workspace:*",
    "@types/express": "^4.17.23",
    "@types/node": "^22",
    "express": "^4.21.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.17"
  }
}