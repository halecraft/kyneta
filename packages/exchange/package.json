{
  "name": "@kyneta/exchange",
  "version": "1.0.0",
  "description": "Substrate-agnostic state exchange — sync for any @kyneta/schema substrate",
  "author": "Duane Johnson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halecraft/kyneta",
    "directory": "packages/exchange"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./src": "./src/index.ts",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "tsup",
    "test": "verify logic",
    "verify": "verify"
  },
  "peerDependencies": {
    "@kyneta/schema": "^1.0.0"
  },
  "devDependencies": {
    "@kyneta/loro-schema": "workspace:^",
    "@kyneta/schema": "workspace:^",
    "@kyneta/yjs-schema": "workspace:^",
    "loro-crdt": "^1.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.17",
    "yjs": "^13.6.30"
  }
}
