{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@kyneta/exchange": ["../../packages/exchange/src/index.ts"],
      "@kyneta/schema": ["../../packages/schema/src/index.ts"],
      "@kyneta/loro-schema": ["../../packages/schema/backends/loro/src/index.ts"],
      "@kyneta/unix-socket-transport": ["../../packages/exchange/transports/unix-socket/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}